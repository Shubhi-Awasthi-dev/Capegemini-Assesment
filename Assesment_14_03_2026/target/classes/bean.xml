    <!--         Constructor Injection -->

    <!-- Book Bean -->
    <bean id="book" class="LMS.Book">
        <constructor-arg name="bookId" value="101"/>
        <constructor-arg name="title" value="Spring"/>
        <constructor-arg name="author" value="Rod Johnson"/>

    </bean>

    <!-- Librarian Bean -->
    <bean id="lib" class="LMS.Librarian">
        <constructor-arg name="librarianId" value="1001"/>
        <constructor-arg name="name" value="Amit"/>
        <constructor-arg name="book" ref="book"/>

    </bean>

</beans>